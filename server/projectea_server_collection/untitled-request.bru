meta {
  name: Java Server life status
  type: http
  seq: 1
}

get {
  url: https://localhost:8082/status
  body: none
  auth: none
}

tests {
  test("Server is on", async function () {
    expect(res.status).to.equal(200);
  
    const msg = (res.getBody() || "").trim();
    expect(msg).to.equal("Server On");
  });
}
