meta {
  name: Post message
  type: http
  seq: 4
}

post {
  url: https://localhost/api/messages
  body: json
  auth: inherit
}

body:json {
  {
    "text": "woof woof bark bark"
  }
}

tests {
  test("message post returns 200 when authenticated", async function () {
    expect(res.status).to.equal(200);
  });
  
  test("message post returns json with message when authenticated", async function () {
    expect(res.body.text).to.equal("woof woof bark bark");
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
